<MyRoot>:
    random_label: random_label # random llabel here maps to random_label in the code
    BoxLayout:
        orientation: "vertical"
        Label:
            text: "NeuralRandom"
            font_size: 64
            # color:  # have to normalize rgb values (val/255)
        Label:
            id: random_label
            text:"-"
            font_size:64
        Button:
            text:"Generate"
            font_size: 32
            size: 100,50
            on_press: root.generate_number()

